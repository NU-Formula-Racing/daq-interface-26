{
  "name": "daq-desktop",
  "version": "0.3.9",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx main/src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:main": "node build/build-main.js",
    "package": "npm run build:main && electron-builder --publish=never",
    "package:mac": "npm run build:main && electron-builder --mac dmg --publish=never",
    "package:linux": "npm run build:main && electron-builder --linux AppImage --publish=never",
    "package:win": "npm run build:main && electron-builder --win portable --publish=never"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@supabase/supabase-js": "^2.104.1",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  },
  "main": "main/dist/electron-main.cjs",
  "build": {
    "appId": "com.nfr26.nfrinterface",
    "productName": "nfrInterface",
    "asar": true,
    "files": [
      "main/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../app/dist",
        "to": "app"
      },
      {
        "from": "migrations",
        "to": "migrations"
      },
      {
        "from": "../parser/dist/parser",
        "to": "parser"
      },
      {
        "from": "../NFR26DBC.csv",
        "to": "NFR26DBC.csv"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "build/postgres-bin/macos-arm64",
          "to": "postgres-bin/macos-arm64"
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "extraResources": [
        {
          "from": "build/postgres-bin/linux-x64",
          "to": "postgres-bin/linux-x64"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "zip"
      ],
      "extraResources": [
        {
          "from": "build/postgres-bin/windows-x64",
          "to": "postgres-bin/windows-x64"
        }
      ]
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
